# When set, all JSON API requests must send this value as
#   Authorization: Bearer <token>   or   X-Api-Token: <token>
# Leave blank for local-only dev.
# API_ACCESS_TOKEN=

# Delta Exchange API credentials
DELTA_API_KEY=
DELTA_API_SECRET=

# Optional bot controls
BOT_DRY_RUN=true
BOT_RISK_PER_TRADE_PCT=1.0
BOT_MAX_DAILY_LOSS_PCT=3.0
BOT_RECONCILE_INTERVAL_SECONDS=15

# WebSocket ingestion controls
WS_RECONNECT_BASE_SECONDS=2
WS_RECENT_FILL_CACHE_SIZE=10000
WS_INGESTION_QUEUE_SIZE=10000
WS_INGESTION_WORKERS=2
WS_METRICS_LOG_INTERVAL_SECONDS=10

# Risk engine controls
RISK_MAINTENANCE_MARGIN_RATE=0.005
RISK_DANGER_MARGIN_RATIO=0.9
RISK_MAX_DAILY_LOSS=-10000
RISK_MAX_EXPOSURE=100000
# ~2% cushion from mark when margin hits danger (long: mark×buffer, short: mark/buffer). Tighter = more whipsaw on crypto.
RISK_DANGER_STOP_BUFFER=0.98

# Microstructure execution controls
MICROSTRUCTURE_IMBALANCE_THRESHOLD=0.2
MICROSTRUCTURE_MIN_SPREAD=0.5
MICROSTRUCTURE_ORDER_QTY=1
EXECUTION_MAX_TOKENS=50
EXECUTION_REFILL_RATE=50

# Adaptive AI controls (meta-decisioning + analysis dashboard SMC synthesis)
# Local: `ollama serve` then `ollama pull <OLLAMA_MODEL>`.
# Cloud: set OLLAMA_API_KEY (ollama.com); app may route to https://ollama.com when URL is localhost.
OLLAMA_URL=http://localhost:11434
OLLAMA_BASE_URL=
OLLAMA_MODEL=llama3
OLLAMA_AGENT_MODEL=
OLLAMA_API_KEY=
OLLAMA_FORCE_LOCAL=false
# SMC digest prompts are large — raise if you see [AiSmcSynthesizer] timeout / empty ai_smc.
# These two override DB admin settings when set (so .env can fix a stale seeded timeout).
OLLAMA_TIMEOUT_SECONDS=90
OLLAMA_MAX_RETRIES=2
#
# Analysis dashboard Redis snapshot + optional Ollama narrative:
# 1) Run Solid Queue: `cd backend && bin/jobs start` (or `foreman start` / Procfile `jobs` process).
# 2) Recurring: `analysis_dashboard_refresh` in config/recurring.yml (every 15m per environment).
# 3) Manual once: `bin/rails runner 'Trading::AnalysisDashboardRefreshJob.perform_now'`
AI_CONFIG_CACHE_SECONDS=10
ADAPTIVE_TRADE_WINDOW=50
REGIME_VOLATILITY_THRESHOLD=50
REGIME_SPREAD_THRESHOLD=1
REGIME_IMBALANCE_THRESHOLD=0.4
BREAKOUT_MIN_SPREAD=0.5
MEAN_REV_IMBALANCE_THRESHOLD=0.45

# Online learning controls
LEARNING_EPSILON=0.05
LEARNING_FREEZE_PNL=-5000

# Bot → trades row (required NOT NULL columns in DB)
# BOT_TRADE_REGIME=unknown
# BOT_TRADE_STRATEGY=multi_timeframe

# Position ledger: Trading::ReconciliationJob (every minute in recurring.yml) recalculates rows with
# needs_reconciliation. Full heal all active: POSITION_RECONCILE_ALL_ACTIVE=true on that job, or run
# `bin/rails trading:reconcile_positions`. Check stored vs formulas: `bin/rails trading:verify_positions`.
# POSITION_RECONCILE_ALL_ACTIVE=false
#
# PostgreSQL "too many clients": lower per-process pool or stop duplicate Rails processes.
# DATABASE_POOL=5
# One-off rake with a crowded server: DATABASE_POOL=1 bin/rails trading:verify_positions
