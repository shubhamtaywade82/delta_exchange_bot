# When set, all JSON API requests must send this value as
#   Authorization: Bearer <token>   or   X-Api-Token: <token>
# Leave blank for local-only dev.
# API_ACCESS_TOKEN=

# Delta Exchange API credentials
DELTA_API_KEY=
DELTA_API_SECRET=

# Optional bot controls
BOT_DRY_RUN=true
BOT_RISK_PER_TRADE_PCT=1.0
BOT_MAX_DAILY_LOSS_PCT=3.0
BOT_RECONCILE_INTERVAL_SECONDS=15

# WebSocket ingestion controls
WS_RECONNECT_BASE_SECONDS=2
WS_RECENT_FILL_CACHE_SIZE=10000
WS_INGESTION_QUEUE_SIZE=10000
WS_INGESTION_WORKERS=2
WS_METRICS_LOG_INTERVAL_SECONDS=10

# Risk engine controls
RISK_MAINTENANCE_MARGIN_RATE=0.005
RISK_DANGER_MARGIN_RATIO=0.9
RISK_MAX_DAILY_LOSS=-10000
RISK_MAX_EXPOSURE=100000
RISK_DANGER_STOP_BUFFER=0.995

# Microstructure execution controls
MICROSTRUCTURE_IMBALANCE_THRESHOLD=0.2
MICROSTRUCTURE_MIN_SPREAD=0.5
MICROSTRUCTURE_ORDER_QTY=1
EXECUTION_MAX_TOKENS=50
EXECUTION_REFILL_RATE=50

# Adaptive AI controls (meta-decisioning only)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
AI_CONFIG_CACHE_SECONDS=10
ADAPTIVE_TRADE_WINDOW=50
REGIME_VOLATILITY_THRESHOLD=50
REGIME_SPREAD_THRESHOLD=1
REGIME_IMBALANCE_THRESHOLD=0.4
BREAKOUT_MIN_SPREAD=0.5
MEAN_REV_IMBALANCE_THRESHOLD=0.45

# Online learning controls
LEARNING_EPSILON=0.05
LEARNING_FREEZE_PNL=-5000

# Bot → trades row (required NOT NULL columns in DB)
# BOT_TRADE_REGIME=unknown
# BOT_TRADE_STRATEGY=multi_timeframe
