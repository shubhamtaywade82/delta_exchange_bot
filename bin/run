#!/usr/bin/env ruby
# frozen_string_literal: true

require "dotenv"
Dotenv.load

$LOAD_PATH.unshift(File.expand_path("../lib", __dir__))

require "bot/runner"

begin
  config = Bot::Config.load
  Bot::Runner.new(config: config).start
rescue => e
  warn "Fatal startup error: #{e.message}"
  exit 1
end
