#!/usr/bin/env bash

# Use foreman if available, otherwise fallback to simple background processes
if command -v foreman &> /dev/null; then
  echo "🚀 Starting all services with foreman..."
  foreman start -f Procfile
else
  echo "⚠️ foreman not found. Falling back to parallel startup (web + bot + Solid Queue + frontend)..."
  echo "   Tip: gem install foreman to use Procfile; or run jobs alone: cd backend && bin/jobs start"
  (cd backend && bin/rails s) &
  (cd backend && bin/bot) &
  (cd backend && bin/jobs start) &
  (cd frontend && npm run dev) &
  wait
fi
