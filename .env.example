# After git pull: cd backend && bin/rails db:migrate
# (Solid Queue tables required for Procfile `jobs` / ./bin/dev)

DELTA_API_KEY=your_api_key_here
DELTA_API_SECRET=your_api_secret_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id
TZ=Asia/Kolkata
BOT_MODE= # dry_run | testnet | live

# Trading::Runner (default ./bin/dev bot process):
# paper | live | unset — unset uses paper when Bot mode is dry_run (see Trading::PaperTrading).
# EXECUTION_MODE=paper
# Optional: LEGACY_BOT_RUNNER=1 uses Bot::Runner instead of Trading::Runner.
# Bounded REST waits inside MultiTimeframe (prevents hung ticker/trades from freezing Redis strategy_state):
# STRATEGY_REST_FETCH_TIMEOUT_S=12
# STRATEGY_CANDLE_FETCH_TIMEOUT_S=25
# Throttle public /history/candles: gap between 1h→15m→1m fetches per symbol; retries if bar count < required.
# STRATEGY_CANDLE_RESOLUTION_STAGGER_S=0.4
# STRATEGY_CANDLE_FETCH_MAX_ATTEMPTS=3
# STRATEGY_CANDLE_RETRY_BASE_SLEEP_S=1.25
# One runner "pass" walks every enabled symbol in order; pause in seconds between symbols (rate-limit only).
# Default 1.0s; raise (e.g. 2.5) if you see empty /history/candles responses under burst load.
# RUNNER_STRATEGY_SYMBOL_STAGGER_S=1.0
# How often to start a new full watchlist pass (Setting runner.strategy_interval_seconds in DB, default 30).

# Backend JSON API: require Bearer / X-Api-Token when exposing the API beyond localhost (set in backend/.env).
# API_ACCESS_TOKEN=

# Closed-trade rows (DbWriter) — must match DB NOT NULL on trades.regime / trades.strategy
# BOT_TRADE_REGIME=unknown
# BOT_TRADE_STRATEGY=multi_timeframe
